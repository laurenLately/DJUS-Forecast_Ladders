USE ROLE SYSADMIN;
USE DATABASE DJUS_ML_SANDBOX;
USE SCHEMA PUBLIC;

CREATE OR REPLACE TABLE LADDER_PLAN_OVERRIDES (
  RETAILER              STRING NOT NULL,
  RETAILER_ITEM_ID      STRING NOT NULL,
  ITEM_ID_AT_WEEK       STRING NOT NULL,
  WEEK_ENDING           DATE   NOT NULL,
  SCENARIO              STRING NOT NULL DEFAULT 'FY2026',

  PLAN_UNITS            NUMBER(38,0),
  SUGGESTED_PLAN_UNITS  NUMBER(38,0),

  UPDATED_BY            STRING,
  UPDATED_AT            TIMESTAMP_NTZ(9) DEFAULT CURRENT_TIMESTAMP(),

  CONSTRAINT PK_LADDER_PLAN_OVERRIDES PRIMARY KEY
    (RETAILER, RETAILER_ITEM_ID, ITEM_ID_AT_WEEK, WEEK_ENDING, SCENARIO)
);
