/* ============================================================
   Phase 2 – Tables
   Purpose:
     - Store authoritative autosaved overrides for ladder edits
     - One row per item/week grain
     - No derived columns (math lives in the UI view)
   ============================================================ */

USE ROLE SYSADMIN;
USE DATABASE DJUS_ML_SANDBOX;
USE SCHEMA LADDER_APP;

/* ------------------------------------------------------------
   LADDER_PLAN_OVERRIDES
   ------------------------------------------------------------
   Stores user-entered overrides for PLAN_UNITS and
   SUGGESTED_PLAN_UNITS.

   Notes:
   - This table is the WRITE target for autosave-on-blur
   - Derived fields (receipts, inventory, WOS, etc.)
     are recomputed in the UI view
   - One row per ladder grain
------------------------------------------------------------ */

CREATE TABLE IF NOT EXISTS LADDER_PLAN_OVERRIDES (
  /* --- ladder grain --- */
  RETAILER                STRING       NOT NULL,
  RETAILER_ITEM_ID        STRING       NOT NULL,
  ITEM_ID_AT_WEEK         STRING       NOT NULL,
  WEEK_ENDING             DATE         NOT NULL,

  /* --- editable fields --- */
  PLAN_UNITS              NUMBER(38,0),
  SUGGESTED_PLAN_UNITS    NUMBER(38,0),

  /* --- audit metadata --- */
  UPDATED_AT              TIMESTAMP_NTZ DEFAULT CURRENT_TIMESTAMP(),
  UPDATED_BY              STRING,
  SOURCE_APP              STRING        DEFAULT 'LADDER_UI',

  /* --- constraints --- */
  CONSTRAINT PK_LADDER_PLAN_OVERRIDES
    PRIMARY KEY (
      RETAILER,
      RETAILER_ITEM_ID,
      ITEM_ID_AT_WEEK,
      WEEK_ENDING
    )
);



COMMENT ON TABLE LADDER_PLAN_OVERRIDES IS
'Authoritative autosaved overrides for ladder PLAN_UNITS and SUGGESTED_PLAN_UNITS. Recalculation handled in UI view.';

COMMENT ON COLUMN LADDER_PLAN_OVERRIDES.RETAILER IS
'Retailer identifier (part of ladder grain).';

COMMENT ON COLUMN LADDER_PLAN_OVERRIDES.RETAILER_ITEM_ID IS
'Retailer-specific item identifier (part of ladder grain).';

COMMENT ON COLUMN LADDER_PLAN_OVERRIDES.ITEM_ID_AT_WEEK IS
'Item identifier at weekly grain (supports lifecycle transitions).';

COMMENT ON COLUMN LADDER_PLAN_OVERRIDES.WEEK_ENDING IS
'Retail week ending date (ladder grain).';

COMMENT ON COLUMN LADDER_PLAN_OVERRIDES.PLAN_UNITS IS
'User-overridden plan units for this item/week.';

COMMENT ON COLUMN LADDER_PLAN_OVERRIDES.SUGGESTED_PLAN_UNITS IS
'User-overridden suggested plan units for this item/week.';

COMMENT ON COLUMN LADDER_PLAN_OVERRIDES.UPDATED_AT IS
'Timestamp of last autosave event.';

COMMENT ON COLUMN LADDER_PLAN_OVERRIDES.UPDATED_BY IS
'User or service that performed the autosave.';

COMMENT ON COLUMN LADDER_PLAN_OVERRIDES.SOURCE_APP IS
'Originating application (default: LADDER_UI).';
