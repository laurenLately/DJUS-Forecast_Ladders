USE ROLE SYSADMIN;
USE DATABASE DJUS_ML_SANDBOX;
USE SCHEMA PUBLIC;

CREATE OR REPLACE TABLE LADDER_SCENARIO_CONFIG (
  SCENARIO_CODE    STRING        NOT NULL,  -- e.g. 'FY2026'
  START_ANCHOR_DT  DATE          NOT NULL,  -- e.g. '2026-02-01'
  IS_ACTIVE        BOOLEAN       NOT NULL DEFAULT FALSE,
  CREATED_AT       TIMESTAMP_NTZ NOT NULL DEFAULT CURRENT_TIMESTAMP(),
  CREATED_BY       STRING
);

-- Upsert FY2026 and set active (locked snapshot starting Feb 2026)
MERGE INTO LADDER_SCENARIO_CONFIG t
USING (
  SELECT 'FY2026' AS SCENARIO_CODE, TO_DATE('2026-02-01') AS START_ANCHOR_DT
) s
ON t.SCENARIO_CODE = s.SCENARIO_CODE
WHEN MATCHED THEN UPDATE SET
  START_ANCHOR_DT = s.START_ANCHOR_DT,
  IS_ACTIVE = TRUE,
  CREATED_BY = COALESCE(t.CREATED_BY, 'svc_automation')
WHEN NOT MATCHED THEN INSERT (SCENARIO_CODE, START_ANCHOR_DT, IS_ACTIVE, CREATED_BY)
VALUES (s.SCENARIO_CODE, s.START_ANCHOR_DT, TRUE, 'svc_automation');

-- Ensure only one active scenario
UPDATE LADDER_SCENARIO_CONFIG
SET IS_ACTIVE = IFF(SCENARIO_CODE = 'FY2026', TRUE, FALSE);
