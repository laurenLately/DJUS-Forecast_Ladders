USE ROLE SYSADMIN;
USE DATABASE DJUS_ML_SANDBOX;
USE SCHEMA PUBLIC;

CREATE OR REPLACE VIEW V_LADDER_ACTIVE_SCENARIO_WEEKS AS
WITH cfg AS (
  SELECT SCENARIO_CODE, START_ANCHOR_DT
  FROM LADDER_SCENARIO_CONFIG
  WHERE IS_ACTIVE = TRUE
  QUALIFY ROW_NUMBER() OVER (ORDER BY CREATED_AT DESC) = 1
),
bounds AS (
  SELECT
    cfg.SCENARIO_CODE,
    (SELECT MIN(week_beg_date)
       FROM DJUS_ML_SANDBOX.PUBLIC.RETAIL_WEEK_DIM_2YR w
      WHERE w.week_beg_date >= cfg.START_ANCHOR_DT
    ) AS START_WEEK_BEG,
    (SELECT MIN(week_beg_date)
       FROM DJUS_ML_SANDBOX.PUBLIC.RETAIL_WEEK_DIM_2YR w
      WHERE w.week_beg_date >= DATEADD(year, 1, cfg.START_ANCHOR_DT)
    ) AS NEXT_START_WEEK_BEG
  FROM cfg
)
SELECT
  b.SCENARIO_CODE,
  w.retail_year,
  w.retail_week,
  w.week_beg_date,
  w.week_ending
FROM bounds b
JOIN DJUS_ML_SANDBOX.PUBLIC.RETAIL_WEEK_DIM_2YR w
  ON w.week_beg_date >= b.START_WEEK_BEG
 AND w.week_beg_date <  b.NEXT_START_WEEK_BEG;
